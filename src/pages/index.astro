---
import BaseLayout from '../layouts/BaseLayout.astro';
import Banner from '../components/sections/Banner.astro';
import About from '../components/sections/About.astro';
import ExploreSlider from '../components/sections/ExploreSlider.astro';
import CardSection from '../components/sections/CardSection.astro';
import VolumeSection from '../components/sections/VolumeSection.astro';
import ContactForm from '../components/sections/ContactForm.astro';

import booksVol1 from '../assets/images/books_sec2.png';

const vol1Props = {
  class: 'books_sl_sec_2',
  code_monst_book: booksVol1,
  books_title: 'Processors And Tangled Threads',
  book_sec_title: 'Code Monster Manual Vol. 1',
  books_para_lft: {
    title: 'What programmer should know about processors.',
    paras: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
  },
  books_para_rgt: {
    title: 'Get to know more about workflow',
    paras: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
  },
  books_app_cap:
    'This is an evergreen classic programming book, focused on foundational principles rather than expiring knowledge trends.',
};
---

<BaseLayout title="Home | Kevin Focke">
  <Banner />
  <About />
  <ExploreSlider />
  <CardSection />
  <!-- <CardSection {...vol1Props} /> -->
  <VolumeSection />
  <ContactForm />
</BaseLayout>
